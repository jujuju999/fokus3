# Supabase project credentials — copy to .env.local and fill in.
# Found in the Supabase dashboard under Project Settings -> API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# VAPID public key for web push (generate with: npx web-push generate-vapid-keys).
# The PRIVATE key lives only in the app_config table (service-role access) — never here.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
